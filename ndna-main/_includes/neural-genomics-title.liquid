{% comment %}
Neural Genomics Title Template
Usage: {% include neural-genomics-title.liquid title="Your Page Title" %}
Parameters:
- title: The title text (required)
- subtitle: Optional subtitle text
{% endcomment %}
{% assign heading_tag = include.size | default: "h1" %}
{% assign logo_size = "12em" %}
<div class="page-title-container" style="text-align: center; margin-bottom: {% if include.subtitle %}1em{% else %}1.5em{% endif %};">
  <div style="margin-bottom: 0.5em;">
    <img src="{{ '/assets/img/Neural_genomics_img-1.png' | relative_url }}" alt="Neural Genomics" style="height: {{ logo_size }}; display: block; margin: 0 auto;">
  </div>
  <h1 class="page-title" style="margin: 0; font-family: 'Montserrat', 'Roboto', 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-weight: 700; letter-spacing: -0.02em;">
    <span class="page-title-neural-genomics">{{ include.title }}</span>
  </h1>
</div>
{% if include.subtitle %}
<p style="font-size: 1.1em; color: #666; margin-top: 0; margin-bottom: 1.5em; font-style: italic; text-align: center;">{{ include.subtitle }}</p>
{% endif %}
