{% comment %}
nephos_wind_field.liquid
- Renders a GIF and interactive HTML visualization for wind field data
- Includes a caption below the visualizations
- Parameters:
  - gif_url: Full URL to the GIF file
  - html_path: Path to the interactive HTML file (relative to assets/html_plots/)
  - title: Title for the visualization
  - caption: Optional markdown caption text
{% endcomment %}

{% assign gif_src = site.cdn_url | append: '/assets/gifs/' | append: include.image_path %}
{% if include.interactive_html %}
  {% assign html_src = '/assets/html_plots/' | append: include.interactive_html | relative_url %}
{% endif %}

<!-- GIF -->
<div style="margin: 0.75em auto; max-width: 700px;">
  <a href="{{ gif_src }}" data-lightbox="gallery" data-title="{{ include.title }}" style="display:block; overflow:hidden; border-radius:8px;">
    <img src="{{ gif_src }}" 
         alt="{{ include.title }}"
         style="width: 100%; border-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
  </a>
</div>

<!-- Interactive HTML -->
{% if include.interactive_html %}
<div style="margin: 1em auto; max-width: 800px; height: 500px;">
  <iframe src="{{ html_src }}"
          style="width: 100%; height: 100%; border: none; border-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
  </iframe>
</div>
{% endif %}

<!-- Caption -->
<figcaption style="margin: 0.5em auto; max-width: 800px; font-size: 0.85em; color: #444; text-align: left; line-height: 1.3;">
  {% if include.title %}<strong>{{ include.title }}</strong>{% endif %}
  {% if include.caption %}{{ include.caption | markdownify }}{% endif %}
</figcaption>
