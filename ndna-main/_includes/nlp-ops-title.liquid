{% comment %}
NLP Ops Title Template
{% endcomment %}

{% assign heading_tag = include.size | default: "h1" %}
{% assign logo_size = "12rem" %}

{% capture h1_content %}
<h1 class="page-title" style="margin-bottom: 1rem; font-family: 'Montserrat', 'Roboto', 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-weight: 600; line-height: 1.2em;">
  <img src="{{ include.title_image | relative_url }}" alt="{{ include.logo_alt }}" style="width: {{ logo_size }}; max-height: {{ logo_size }}; flex: 0 0;">
  <span style="display: flex; gap: 0.5rem;">
    <span>-</span>
    <span>{{ include.title }}</span>
  </span>
</h1>
{% endcapture %}

{% if include.video_id %}
<div class="title-wrapper">
  <div class="title-container">
    {{ h1_content }}
    {% include inspiration-video.liquid video_id=include.video_id %}
  </div>
</div>
{% else %}
{{ h1_content }}
{% endif %}

<div class="text-center">
  <p style="color: #06f;font-size: 1.8rem;font-weight: 600;">Micro-summary — details in the book</p>
</div>
