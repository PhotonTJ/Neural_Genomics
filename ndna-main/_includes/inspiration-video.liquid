<div style="text-align: center; margin: 2rem auto; max-width: 900px;">
  {% if include.show_header %}
  <h2 style="font-size: 2rem; font-weight: 700; color: #222; margin: 0 0 1.5rem; border-bottom: 3px solid #0077ff; display: inline-block; padding-bottom: 0.5rem;">
     {{ include.header_title | default: "Inspiration" }}
  </h2>
  {% endif %}
  
  {% if include.embed_disabled %}
    <!-- YouTube-style preview with title -->
    <div style="position: relative; padding-bottom: 56.25%; height: 0; border-radius: 0.5rem; overflow: hidden; box-shadow: 0 6px 20px rgba(0,0,0,0.2); cursor: pointer; transition: transform 0.2s ease;">
      <a href="{{ include.youtube_url | default: 'https://www.youtube.com/watch?v=' | append: include.video_id }}" target="_blank" rel="noopener noreferrer" style="display: block; position: absolute; top: 0; left: 0; width: 100%; height: 100%; text-decoration: none;" onmouseover="this.parentElement.style.transform='scale(1.02)'" onmouseout="this.parentElement.style.transform='scale(1)'">
        <img 
          src="{{ include.preview_image | default: 'https://img.youtube.com/vi/' | append: include.video_id | append: '/maxresdefault.jpg' }}" 
          alt="Watch {{ include.title | default: 'Inspiration Video' }} on YouTube"
          style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; border-radius: 0.5rem;"
        />
        
        <!-- Dark gradient overlay for better text readability -->
        <div style="position: absolute; bottom: 0; left: 0; width: 100%; height: 60%; background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, transparent 100%); border-radius: 0.5rem;"></div>
        
        <!-- Play button overlay -->
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(255,0,0,0.9); border-radius: 50%; width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(255,0,0,0.3);">
          <svg style="width: 35px; height: 35px; fill: white; margin-left: 3px;" viewBox="0 0 24 24">
            <path d="M8,5.14V19.14L19,12.14L8,5.14Z" />
          </svg>
        </div>
        
        <!-- Video title overlay -->
        {% if include.title %}
        <div style="position: absolute; bottom: 50px; left: 20px; right: 20px; color: white; font-size: 18px; font-weight: 700; line-height: 1.3; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">
          {{ include.title }}
        </div>
        {% endif %}
        
        <!-- YouTube branding and watch indicator -->
        <div style="position: absolute; bottom: 15px; left: 20px; display: flex; align-items: center; gap: 10px;">
          <div style="background: #ff0000; color: white; padding: 4px 16px; border-radius: 3px; font-size: 12px; font-weight: 700;">
            ▶ YouTube
          </div>
          <div style="color: white; font-size: 14px; font-weight: 600; text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">
            Click to Watch
          </div>
        </div>
        
        <!-- Duration badge (top right) -->
        <div style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.8); color: white; padding: 4px 8px; border-radius: 3px; font-size: 12px; font-weight: 600;">
          {{ include.duration | default: 'HD' }}
        </div>
      </a>
    </div>
  {% else %}
    <!-- Regular embedded video -->
    <div style="position: relative; padding-bottom: 56.25%; height: 0; border-radius: 0.5rem; overflow: hidden; box-shadow: 0 6px 20px rgba(0,0,0,0.2);">
      <iframe 
        src="{{ include.youtube_url | default: 'https://www.youtube.com/embed/' | append: include.video_id }}" 
        title="Inspiration Video"
        style="position: absolute; top:0; left:0; width:100%; height:100%; border:0; border-radius: 0.5rem;" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen>
      </iframe>
    </div>
  {% endif %}
  {% if include.caption %}
  <p>
     {{ include.caption | markdownify }}
  </p>
  {% endif %}
</div>